{
  "name": "aether-art-uniapp",
  "version": "0.1.0",
  "private": true,
  "description": "天异艺术 uni-app + Vue 多端 WebUI 正式工程",
  "scripts": {
    "dev:custom": "uni -p",
    "dev:h5": "uni",
    "dev:h5:5180": "uni --port 5180",
    "build:h5": "uni build",
    "type-check": "vue-tsc --noEmit",
    "lint": "npm run lint:eslint && npm run lint:style && npm run lint:format",
    "lint:eslint": "eslint src --ext .ts,.vue --max-warnings=0",
    "lint:style": "stylelint \"src/**/*.{vue,scss,css}\" --allow-empty-input",
    "lint:format": "prettier --check \"src/**/*.{ts,vue,scss}\" \"*.{json,ts,js,html}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\" \"*.{json,ts,js,html}\""
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "lucide-vue-next": "^0.542.0",
    "pinia": "2.1.7",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vue/tsconfig": "0.9.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "9.33.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "5.9.3",
    "vite": "5.2.8",
    "vue-eslint-parser": "9.4.3",
    "vue-tsc": "3.2.6"
  }
}
